# Lumi – KI-Briefing-Assistentin
# Ohne diesen Key läuft Lumi automatisch im regelbasierten Fallback-Modus (deterministisches
# Slot-Filling). Mit Key formuliert Claude die Fragen dynamisch und branchenangepasst.
ANTHROPIC_API_KEY=

# Optional: Modell überschreiben (Default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: E-Mail-Empfänger für eingehende Briefings (für spätere Mail-Anbindung).
BRIEFING_RECIPIENT_EMAIL=
